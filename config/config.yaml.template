# ============================================
# A股量化选股系统 - 主配置文件模板
# ============================================
# 使用说明：
# 1. 复制此文件为 config.yaml
# 2. 填入你的钉钉机器人配置
# 3. 不要提交 config.yaml 到Git仓库（已加入.gitignore）

data_dir: data

# 数据源配置
data_source:
  default_provider: "akshare"  # 可选: akshare / tushare
  akshare:
    allow_mock_data: false  # 仅演示/开发时可显式改为 true，真实选股请保持 false
  tushare:
    token: ""  # 推荐优先使用环境变量 TUSHARE_TOKEN 或本机 config/config_local.yaml

# 钉钉机器人配置
# 1. 在钉钉群中添加自定义机器人
# 2. 复制 webhook URL 和加签密钥
# 3. enabled=false 表示保留配置但默认不发送
dingtalk:
  enabled: false
  webhook_url: ""
  secret: ""

# 定时任务配置
schedule:
  time: "17:00"  # 每日执行时间

# Web 配置
web:
  host: "127.0.0.1"
  port: 5080
  auto_port: true
  allow_lan: false  # 如需局域网访问才改为 true

# 威科夫 AI 分析配置
# deepseek_api_key 请放在 config/config_local.yaml 或环境变量 DEEPSEEK_API_KEY
wyckoff_ai:
  provider: "deepseek"
  base_url: "https://api.deepseek.com"
  model: "deepseek-v4-pro"
  timeout_seconds: 90
  deepseek_api_key: ""

# 数据更新配置
update:
  lookback_days: 10
  skip_failed: true

# 选股执行配置
selection:
  mode: parallel      # parallel / sequential
  backend: process    # process / thread / sequential
  max_workers: 12     # 激进提速模式默认优先进程并行
  chunk_size: 50      # 每个工作单元处理的股票数
